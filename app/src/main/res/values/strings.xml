    <!-- Guide -->
    <string name="guide_title">User Guide</string>
    <string name="guide_step1_title">Fill your own company data</string>
    <string name="guide_step1_body">Use the \"Your Company\" selector on the Home screen. Add your company in Companies if needed. Required first – without it, the app can mismatch counterparty and own company data. Own company data is also required in the export XML file.</string>
    <string name="guide_step2_title">Taking photos</string>
    <string name="guide_step2_body">1. Tap Scan with Camera\n2. Choose Purchase or Sales\n3. Tap Capture to take a photo\n4. Review extracted data, edit if needed\n5. Tap Confirm and Save</string>
    <string name="guide_step3_title">Importing files</string>
    <string name="guide_step3_body">1. Tap Import files\n2. Choose Purchase or Sales\n3. Pick images or PDF files\n4. Wait for extraction\n5. Review each invoice, edit if needed\n6. Tap Save and next or Confirm and Save</string>
    <string name="guide_step4_title">Verifying invoices</string>
    <string name="guide_step4_body">1. Go to Exports\n2. Expand a month to see invoices\n3. Tap the Edit icon on any invoice to fix fields\n4. Check invoices marked with [to check] for validation errors\n5. Tap Save Changes</string>
    <string name="guide_step5_title">Export XML or Excel</string>
    <string name="guide_step5_body">1. Go to Exports\n2. Select a year and tap Export on a month (or Export All)\n3. Choose Export Excel or Export XML (i.SAF)\n4. Save to Downloads or Share to another app</string>
    <string name="guide_step6_title">Submit to i.SAF</string>
    <string name="guide_step6_body">1. Export XML from the app (Share or Save)\n2. Log in to the VMI i.SAF portal (vmi.lt)\n3. Go to i.SAF → Įkelti rinkmeną (Upload file)\n4. Drag and drop the XML file or tap Pasirinkite rinkmeną iš kompiuterio to select it\n5. The file will appear in the list once accepted</string>
    <string name="cd_guide_isaf_image">VMI i.SAF upload page</string>

